[core]
  editor = nvim
  pager = delta
  excludesfile = ~/.gitignore_global

[interactive]
  diffFilter = delta --color-only

[rerere]
	enabled = true
  autoupdate = true

[pull]
  rebase = true

[delta]
  navigate = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[alias]
  amend = commit --amend --no-edit
  fu = push -u origin HEAD
  ffu = push -fu origin HEAD
  ls = ls-files

[include]
  path = .gitconfig.local

